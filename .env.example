# HubSpot private app token — generate from your HubSpot account settings
# Required scopes: crm.objects.contacts.read, crm.objects.deals.read, crm.objects.owners.read
HUBSPOT_API_KEY=

# Google Analytics 4
# Property ID from GA4 Admin > Property Settings (numbers only, no "properties/" prefix)
GA4_PROPERTY_ID=

# GA4 service account credentials — paste the full JSON as a single-line string
# e.g. {"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GA4_CREDENTIALS=

# Shopify (Phase 2 — leave blank for now)
SHOPIFY_API_KEY=
SHOPIFY_STORE_URL=

# Feature flag — set to "true" when Shopify credentials are configured and ready
SHOPIFY_INTEGRATION_READY=false
