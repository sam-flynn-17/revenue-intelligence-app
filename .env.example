# HubSpot private app token — generate from your HubSpot account settings
# Required scopes: crm.objects.contacts.read, crm.objects.deals.read, crm.objects.owners.read
HUBSPOT_API_KEY=

# Google Analytics 4 — Manual override (recommended, no service account needed)
# Pull these figures from GA4 > Reports > Acquisition / Engagement and update periodically.
# When all four are set, they take priority over the service account path below.
GA4_SESSIONS=
GA4_ADD_TO_BASKET=
GA4_CHECKOUTS=
GA4_PURCHASES=

# GA4 service account path (optional — only needed if you want live API data)
# Requires granting the service account Viewer access via the GA4 Admin API (not the UI).
GA4_PROPERTY_ID=
GA4_CREDENTIALS=

# Shopify (Phase 2 — leave blank for now)
SHOPIFY_API_KEY=
SHOPIFY_STORE_URL=

# Feature flag — set to "true" when Shopify credentials are configured and ready
SHOPIFY_INTEGRATION_READY=false
